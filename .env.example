# ─── Supabase ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── RevenueCat ───────────────────────────────────────────────────────────────
# Get these from app.revenuecat.com → Project → API Keys
# iOS key starts with "appl_", Android key starts with "goog_"
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_ios_key_here
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_android_key_here
